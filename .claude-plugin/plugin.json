{
  "name": "maximous",
  "version": "0.1.1",
  "description": "Lightweight SQLite brain for multi-agent orchestration — shared memory, messaging, task coordination, and observation for Claude Code agents",
  "author": {
    "name": "Laurent",
    "url": "https://github.com/laurentlouk/maximous"
  },
  "repository": "https://github.com/laurentlouk/maximous",
  "license": "MIT",
  "keywords": ["multi-agent", "orchestration", "sqlite", "mcp", "coordination"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-db.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "maximous": {
      "command": "maximous",
      "args": ["--db", ".maximous/brain.db"]
    }
  }
}
